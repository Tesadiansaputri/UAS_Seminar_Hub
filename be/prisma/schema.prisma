generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int               @id @default(autoincrement())
  name      String
  email     String            @unique
  password  String
  role      String            @default("USER")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  bobots    Bobot[]
  hasil     Hasil[]
  ratings   RatingPembicara[]

  @@map("users")
}

model Category {
  id            Int       @id @default(autoincrement()) @map("id_category")
  category_name String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  seminars      Seminar[]

  @@map("category")
}

model Level {
  id          Int       @id @default(autoincrement())
  nama_level  String
  nilai_level Int
  seminars    Seminar[]

  @@map("level")
}

model Speaker {
  id              Int               @id @default(autoincrement())
  nama            String
  email           String            @unique
  bidang_keahlian String
  rating          Float             @default(0)
  seminar         SpeakerSeminar[]
  ratings         RatingPembicara[]

  @@map("speaker")
}

model Seminar {
  id             Int                    @id @default(autoincrement()) @map("id_seminar")
  seminar_name   String
  tanggal        DateTime
  harga          BigInt
  kuota_tersedia Int
  id_category    Int
  id_level       Int
  hasil          Hasil[]
  fasilitas      KelengkapanFasilitas[]
  speakers       SpeakerSeminar[]
  category       Category               @relation(fields: [id_category], references: [id])
  level          Level                  @relation(fields: [id_level], references: [id])

  @@index([id_category], map: "seminar_id_category_fkey")
  @@index([id_level], map: "seminar_id_level_fkey")
  @@map("seminar")
}

model SpeakerSeminar {
  id        Int     @id @default(autoincrement())
  seminarId Int
  speakerId Int
  seminar   Seminar @relation(fields: [seminarId], references: [id])
  speaker   Speaker @relation(fields: [speakerId], references: [id])

  @@index([seminarId], map: "pengisi_materi_seminarId_fkey")
  @@index([speakerId], map: "pengisi_materi_speakerId_fkey")
  @@map("pengisi_materi")
}

model Fasilitas {
  id              Int                    @id @default(autoincrement())
  nama_fasilitas  String
  nilai_fasilitas Int
  seminar         KelengkapanFasilitas[]

  @@map("fasilitas")
}

model KelengkapanFasilitas {
  seminarId   Int
  fasilitasId Int
  fasilitas   Fasilitas @relation(fields: [fasilitasId], references: [id])
  seminar     Seminar   @relation(fields: [seminarId], references: [id])

  @@id([seminarId, fasilitasId])
  @@index([fasilitasId], map: "kelengkapan_fasilitas_fasilitasId_fkey")
  @@map("kelengkapan_fasilitas")
}

model RatingPembicara {
  id        Int     @id @default(autoincrement())
  rating    Float
  userId    Int
  speakerId Int
  speaker   Speaker @relation(fields: [speakerId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([speakerId], map: "rating_pembicara_speakerId_fkey")
  @@index([userId], map: "rating_pembicara_userId_fkey")
  @@map("rating_pembicara")
}

model Bobot {
  id              Int      @id @default(autoincrement())
  userId          Int
  bobot_harga     Float
  bobot_kuota     Float
  bobot_rating    Float
  bobot_fasilitas Float
  createdAt       DateTime @default(now())
  bobot_level     Float
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "bobot_userId_fkey")
  @@map("bobot")
}

model SubKriteria {
  id    Int    @id @default(autoincrement())
  jenis String
  nama  String
  nilai Float
  max   Float?
  min   Float?

  @@map("sub_kriteria")
}

model Hasil {
  id        Int      @id @default(autoincrement())
  userId    Int
  seminarId Int
  metode    String
  nilai     Float
  ranking   Int
  createdAt DateTime @default(now())
  seminar   Seminar  @relation(fields: [seminarId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([seminarId], map: "hasil_seminarId_fkey")
  @@index([userId], map: "hasil_userId_fkey")
  @@map("hasil")
}

model Kriteria {
  id     Int    @id @default(autoincrement())
  kode   String @unique
  nama   String
  jenis  String
  sumber String

  @@map("kriteria")
}
