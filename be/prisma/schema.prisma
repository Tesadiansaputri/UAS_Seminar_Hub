generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bobots   Bobot[]
  hasil    Hasil[]
  ratings  RatingPembicara[]

  @@map("users")
}

//////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////

model Category {
  id            Int      @id @default(autoincrement()) @map("id_category")
  category_name String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  seminars Seminar[]

  @@map("category")
}

//////////////////////////////////////////////////
// LEVEL
//////////////////////////////////////////////////

model Level {

  id Int @id @default(autoincrement())

  nama_level String
  nilai_level Int

  seminars Seminar[]

  @@map("level")
}

//////////////////////////////////////////////////
// PEMBICARA
//////////////////////////////////////////////////

model Speaker {

  id Int @id @default(autoincrement())

  nama String
  email String @unique
  bidang_keahlian String

  rating Float @default(0)

  seminar SpeakerSeminar[]

  ratings RatingPembicara[]

  @@map("speaker")
}

//////////////////////////////////////////////////
// SEMINAR
//////////////////////////////////////////////////

model Seminar {

  id Int @id @default(autoincrement()) @map("id_seminar")

  seminar_name String

  tanggal DateTime

  harga BigInt

  kuota_tersedia Int

  id_category Int

  id_level Int

  category Category @relation(fields:[id_category],references:[id])

  level Level @relation(fields:[id_level],references:[id])

  speakers SpeakerSeminar[]

  fasilitas KelengkapanFasilitas[]

  hasil Hasil[]

  @@map("seminar")
}

//////////////////////////////////////////////////
// MANY TO MANY PEMBICARA
//////////////////////////////////////////////////

model SpeakerSeminar{

  id Int @id @default(autoincrement())

  seminarId Int

  speakerId Int

  seminar Seminar @relation(fields:[seminarId],references:[id])

  speaker Speaker @relation(fields:[speakerId],references:[id])

  @@map("pengisi_materi")
}

//////////////////////////////////////////////////
// FASILITAS
//////////////////////////////////////////////////

model Fasilitas{

  id Int @id @default(autoincrement())

  nama_fasilitas String

  nilai_fasilitas Int

  seminar KelengkapanFasilitas[]

  @@map("fasilitas")
}

//////////////////////////////////////////////////
// MANY TO MANY SEMINAR FASILITAS
//////////////////////////////////////////////////

model KelengkapanFasilitas{

  seminarId Int

  fasilitasId Int

  seminar Seminar @relation(fields:[seminarId],references:[id])

  fasilitas Fasilitas @relation(fields:[fasilitasId],references:[id])

  @@id([seminarId,fasilitasId])

  @@map("kelengkapan_fasilitas")
}

//////////////////////////////////////////////////
// RATING PEMBICARA
//////////////////////////////////////////////////

model RatingPembicara{

  id Int @id @default(autoincrement())

  rating Float

  userId Int

  speakerId Int

  user User @relation(fields:[userId],references:[id])

  speaker Speaker @relation(fields:[speakerId],references:[id])

  @@map("rating_pembicara")
}

//////////////////////////////////////////////////
// BOBOT USER
//////////////////////////////////////////////////

model Bobot{

  id Int @id @default(autoincrement())

  userId Int

  bobot_harga Float

  bobot_kuota Float

  bobot_rating Float

  bobot_level Float

  bobot_fasilitas Float

  createdAt DateTime @default(now())

  user User @relation(fields:[userId],references:[id])

  @@map("bobot")
}
model SubKriteria {

  id Int @id @default(autoincrement())

  jenis String
  nama String
  nilai Float

  @@map("sub_kriteria")
}

//////////////////////////////////////////////////
// HASIL SPK
//////////////////////////////////////////////////

model Hasil{

  id Int @id @default(autoincrement())

  userId Int

  seminarId Int

  metode String

  nilai Float

  ranking Int

  createdAt DateTime @default(now())

  user User @relation(fields:[userId],references:[id])

  seminar Seminar @relation(fields:[seminarId],references:[id])

  @@map("hasil")
}

model Kriteria {
  id      Int    @id @default(autoincrement())
  kode    String @unique
  nama    String
  jenis   String
  sumber  String

  @@map("kriteria")
}